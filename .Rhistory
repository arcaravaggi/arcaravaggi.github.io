# ------------------------------
ggplot(bp, aes(x=Dose, y=BP)) +
geom_boxplot(outlier.shape = NA, fill="lightblue") +
geom_jitter(width=0.1, size=2, color="black") +
stat_compare_means(comparisons = list(c("Low","High"), c("Medium","High")),
method="t.test", label = "p.format") +
stat_compare_means(label.y = max(bp$BP) + 10) + # overall ANOVA
labs(
title = "Figure 2. Systolic blood pressure across drug dosages",
x = "Drug dosage",
y = "Systolic blood pressure (mmHg)"
) +
theme_bw() +
theme(plot.title = element_text(hjust = 0.5))
# ------------------------------
# Talk-style plot (simplified)
# ------------------------------
ggplot(bp, aes(x=Dose, y=BP)) +
geom_boxplot(outlier.shape = NA, fill="lightgreen") +
geom_jitter(width=0.1, size=2, color="black") +
# Only key comparison: Low vs High
stat_compare_means(comparisons = list(c("Low","High")), method="t.test", label = "p.signif") +
labs(
title = "Higher drug dose lowers blood pressure",
x = "Drug dosage",
y = "Systolic BP (mmHg)"
) +
