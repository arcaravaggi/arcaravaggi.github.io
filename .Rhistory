# ------------------------------
# Simulate data: Grazing intensity vs Species richness
# ------------------------------
set.seed(42)
low <- rnorm(10, mean = 22, sd = 2.5)
medium <- rnorm(10, mean = 19, sd = 2.5)
high <- rnorm(10, mean = 14, sd = 2.5)
species <- data.frame(
Richness = c(low, medium, high),
Grazing = factor(rep(c("Low", "Medium", "High"), each = 10), levels = c("Low","Medium","High"))
)
# ------------------------------
# Dissertation-style plot
# ------------------------------
ggplot(species, aes(x=Grazing, y=Richness)) +
geom_boxplot(outlier.shape = NA, fill="lightblue", color="black") +
geom_jitter(width=0.1, size=2, color="black") +
stat_compare_means(comparisons = list(c("Low","High"), c("Medium","High")),
method="t.test", label = "p.format") +
stat_compare_means(label.y = max(species$Richness) + 3) + # overall ANOVA
scale_y_continuous(labels = number_format(accuracy = 1)) +
labs(
title = "Figure 2. Plant species richness across grazing intensities",
x = "Grazing intensity",
y = "Species richness (species per 1 m² quadrat)"
) +
theme_bw() +
theme(plot.title = element_text(hjust = 0.5))
# ------------------------------
# Talk-style plot (simplified + annotation)
# ------------------------------
ggplot(species, aes(x=Grazing, y=Richness)) +
geom_boxplot(outlier.shape = NA, fill="lightblue", color="black") +
geom_jitter(width=0.1, size=2, color="black") +
# Only key comparison: Low vs High
stat_compare_means(comparisons = list(c("Low","High")), method="t.test", label = "p.signif") +
labs(
title = "High grazing reduces plant diversity",
x = "Grazing intensity",
y = "Species richness"
) +
theme_bw() +
theme(plot.title = element_text(hjust = 0.5)) +
# Add annotation showing difference
annotate("text", x = 2, y = max(species$Richness) + 1.5, label = "↓ ~8 species vs Low", color="red", fontface="bold") +
annotate("segment", x = 1, xend = 3, y = max(species$Richness) + 1, yend = max(species$Richness) + 1,
arrow = arrow(length = unit(0.2, "cm")), color="red")
# Dissertation-style plot (biomed) with p < 0.0001 for tiny p-values
ggplot(bp, aes(x=Dose, y=BP)) +
geom_boxplot(outlier.shape = NA, fill="lightblue", color="black") +
geom_jitter(width=0.1, size=2, color="black") +
# Pairwise comparisons
stat_compare_means(
comparisons = list(c("Low","High"), c("Medium","High")),
method = "t.test",
label = "p.format",
aes(label = ifelse(..p.format.. < 0.0001, "<0.0001", ..p.format..))
) +
# Overall ANOVA
stat_compare_means(
label.y = max(bp$BP) + 10,
method = "anova",
aes(label = "One-way ANOVA: p < 0.0001") # hardcode
) +
scale_y_continuous(labels = scales::number_format(accuracy = 1)) +
labs(
title = "Figure 2. Systolic blood pressure across drug dosages",
x = "Drug dosage",
y = "Systolic blood pressure (mmHg)"
) +
theme_bw() +
theme(plot.title = element_text(hjust = 0.5))
# Define comparisons
comparisons <- list(c("Low","High"), c("Medium","High"))
# Manual labels (enforce "<0.0001" for tiny p-values)
p_labels <- c("<0.0001", "0.02")  # match the two comparisons
ggplot(bp, aes(x=Dose, y=BP)) +
geom_boxplot(outlier.shape = NA, fill="lightblue", color="black") +
geom_jitter(width=0.1, size=2, color="black") +
# Manual annotation for each comparison
stat_pvalue_manual(
data = data.frame(
group1 = c("Low", "Medium"),
group2 = c("High", "High"),
y.position = c(max(bp$BP)+2, max(bp$BP)+6),
label = p_labels
),
label = "label",
xmin = "group1",
xmax = "group2"
) +
# Overall ANOVA (manual)
annotate("text", x = 1.5, y = max(bp$BP)+10,
label = "One-way ANOVA: F(2,27) = 12.4, p < 0.0001") +
scale_y_continuous(labels = scales::number_format(accuracy = 1)) +
labs(
title = "Figure 2. Systolic blood pressure across drug dosages",
x = "Drug dosage",
y = "Systolic blood pressure (mmHg)"
) +
theme_bw() +
theme(plot.title = element_text(hjust = 0.5))
# Simulate data
set.seed(42)
low <- rnorm(10, mean = 22, sd = 2.5)
medium <- rnorm(10, mean = 19, sd = 2.5)
high <- rnorm(10, mean = 14, sd = 2.5)
species <- data.frame(
Richness = c(low, medium, high),
Grazing = factor(rep(c("Low", "Medium", "High"), each = 10), levels = c("Low","Medium","High"))
)
# Define comparisons
comparisons <- list(c("Low","High"), c("Medium","High"))
# Manual labels for pairwise comparisons
p_labels <- c("<0.0001", "0.02")  # example values
# Dissertation-style plot
ggplot(species, aes(x=Grazing, y=Richness)) +
geom_boxplot(outlier.shape = NA, fill="lightblue", color="black") +
geom_jitter(width=0.1, size=2, color="black") +
# Manual p-value annotations
stat_pvalue_manual(
data = data.frame(
group1 = c("Low", "Medium"),
group2 = c("High", "High"),
y.position = c(max(species$Richness)+1, max(species$Richness)+3),
label = p_labels
),
label = "label",
xmin = "group1",
xmax = "group2"
) +
# Overall ANOVA (manual)
annotate("text", x = 1.5, y = max(species$Richness)+5,
label = "One-way ANOVA: F(2,27) = 8.46, p < 0.0001") +
scale_y_continuous(labels = number_format(accuracy = 1)) +
labs(
title = "Figure 2. Plant species richness across grazing intensities",
x = "Grazing intensity",
y = "Species richness (species per 1 m² quadrat)"
) +
theme_bw() +
theme(plot.title = element_text(hjust = 0.5))
# -----------------------------------------
# Camera Trap + CV Bias Propagation Demo
# Species: Pine Marten
# -----------------------------------------
set.seed(42)
library(lme4)
library(dplyr)
# -----------------------------
# 1. Simulate Study Design
# -----------------------------
n_sites <- 100
n_occasions <- 5
# Assign habitat
habitat <- rep(c("Grassland", "Woodland"), each = n_sites/2)
# True occupancy probabilities
psi_grass <- 0.3
psi_wood  <- 0.6
psi <- ifelse(habitat == "Grassland", psi_grass, psi_wood)
# True occupancy state
z <- rbinom(n_sites, 1, psi)
# Expand to detection occasions
dat <- expand.grid(site = 1:n_sites,
occasion = 1:n_occasions)
dat$habitat <- rep(habitat, each = n_occasions)
dat$z <- rep(z, each = n_occasions)
# -----------------------------
# 2. Ecological Detection
# -----------------------------
p_ecol <- 0.5  # ecological detection probability
dat$det_ecol <- rbinom(nrow(dat), 1, dat$z * p_ecol)
# -----------------------------
# 3. Algorithmic Recall
# -----------------------------
recall_grass <- 0.85
recall_wood  <- 0.50
dat$recall <- ifelse(dat$habitat == "Grassland",
recall_grass,
recall_wood)
# Observed detection after CV
dat$det_obs <- rbinom(nrow(dat), 1, dat$det_ecol * dat$recall)
# -----------------------------
# 4. Summarise True vs Observed
# -----------------------------
true_occ <- data.frame(habitat = habitat,
z = z) %>%
group_by(habitat) %>%
summarise(true_occupancy = mean(z))
observed_occ <- dat %>%
group_by(site, habitat) %>%
summarise(ever_detected = max(det_obs), .groups = "drop") %>%
group_by(habitat) %>%
summarise(naive_occupancy = mean(ever_detected))
true_occ
observed_occ
# -----------------------------
# 5. Fit Naïve GLMM
# -----------------------------
model <- glmer(det_obs ~ habitat + (1|site),
data = dat,
family = binomial)
summary(model)
library(ggplot2)
library(dplyr)
# Summarise for plotting
plot_df <- dat %>%
group_by(habitat) %>%
summarise(
true_occ = mean(z),
naive_occ = mean(pmax(det_obs,0))
) %>%
pivot_longer(cols = c(true_occ, naive_occ),
names_to = "Type", values_to = "Occupancy")
library(tidyverse)
# Summarise for plotting
plot_df <- dat %>%
group_by(habitat) %>%
summarise(
true_occ = mean(z),
naive_occ = mean(pmax(det_obs,0))
) %>%
pivot_longer(cols = c(true_occ, naive_occ),
names_to = "Type", values_to = "Occupancy")
ggplot(plot_df, aes(x = habitat, y = Occupancy, fill = Type)) +
geom_bar(stat="identity", position="dodge") +
scale_fill_manual(values = c("true_occ"="forestgreen",
"naive_occ"="goldenrod")) +
ylim(0,1) +
labs(title="Pine Marten Occupancy: True vs Naïve Detection",
y="Occupancy Probability",
x="Habitat") +
theme_minimal()
# -----------------------------------------
# Pine Marten Demo: Bar Chart + Schematic Slide
# -----------------------------------------
# Load packages
library(ggplot2)
library(dplyr)
library(tidyr)
library(patchwork)  # For combining plots
set.seed(42)
# -----------------------------
# 1. Simulate Data
# -----------------------------
n_sites <- 100
n_occasions <- 5
habitat <- rep(c("Grassland","Woodland"), each=n_sites/2)
psi <- ifelse(habitat=="Grassland", 0.3, 0.6)
z <- rbinom(n_sites,1,psi)
dat <- expand.grid(site = 1:n_sites, occasion=1:n_occasions)
dat$habitat <- rep(habitat, each=n_occasions)
dat$z <- rep(z, each=n_occasions)
# Ecological detection
p_ecol <- 0.5
dat$det_ecol <- rbinom(nrow(dat),1, dat$z*p_ecol)
# Algorithmic recall
recall_grass <- 0.85
recall_wood  <- 0.50
dat$recall <- ifelse(dat$habitat=="Grassland", recall_grass, recall_wood)
# Observed detection
dat$det_obs <- rbinom(nrow(dat),1, dat$det_ecol*dat$recall)
# -----------------------------
# 2. Summarise for plotting
# -----------------------------
plot_df <- dat %>%
group_by(habitat) %>%
summarise(
true_occ = mean(z),
naive_occ = mean(pmax(det_obs,0))
) %>%
pivot_longer(cols = c(true_occ, naive_occ),
names_to="Type",
values_to="Occupancy")
plot_df$Type <- factor(plot_df$Type, levels=c("true_occ","naive_occ"),
labels=c("True Occupancy","Observed Detection"))
# -----------------------------
# 3. Bar Chart
# -----------------------------
p1 <- ggplot(plot_df, aes(x=habitat, y=Occupancy, fill=Type)) +
geom_bar(stat="identity", position="dodge") +
scale_fill_manual(values=c("True Occupancy"="forestgreen",
"Observed Detection"="goldenrod")) +
ylim(0,1) +
labs(title="Pine Marten Occupancy: True vs Observed Detection",
y="Occupancy Probability",
x="Habitat") +
theme_minimal(base_size=14) +
theme(legend.position="top")
# -----------------------------
# 4. Schematic Diagram
# -----------------------------
schematic <- data.frame(
xstart = c(1,2,3,4,5),
xend   = c(2,3,4,5,6),
y      = c(1,1,1,1,1),
label  = c("True Occupancy (ψ)","Ecological Detection (p_ecol)",
"Algorithmic Detection (p_alg)",
"Observed Detection","Model / Inference")
)
p2 <- ggplot() +
geom_segment(data=schematic, aes(x=xstart, xend=xend, y=y, yend=y),
arrow=arrow(length=unit(0.3,"cm")), size=1.2, color="steelblue") +
geom_text(data=schematic, aes(x=xstart, y=y+0.25, label=label), size=5) +
xlim(0.5,6.5) + ylim(0.5,1.5) +
theme_void() +
labs(title="Dual Detection Process: Ecological + Algorithmic") +
theme(plot.title=element_text(hjust=0.5, size=16))
# -----------------------------
# 5. Combine with patchwork
# -----------------------------
combined <- p1 / p2 + plot_layout(heights = c(1, 0.6))  # Bar chart taller than schematic
# Display combined figure
print(combined)
# -----------------------------------------
# Pine Marten Demo: Threshold Choice Impact
# -----------------------------------------
# Load packages
library(ggplot2)
library(dplyr)
library(tidyr)
set.seed(42)
# -----------------------------
# 1. Simulate Study Design
# -----------------------------
n_sites <- 100
n_occasions <- 5
habitat <- rep(c("Grassland","Woodland"), each=n_sites/2)
psi <- ifelse(habitat=="Grassland", 0.3, 0.6)
z <- rbinom(n_sites,1,psi)
dat <- expand.grid(site = 1:n_sites, occasion=1:n_occasions)
dat$habitat <- rep(habitat, each=n_occasions)
dat$z <- rep(z, each=n_occasions)
# Ecological detection
p_ecol <- 0.5
dat$det_ecol <- rbinom(nrow(dat),1, dat$z*p_ecol)
# Algorithmic predicted probability
# Woodland has lower model confidence
dat$prob <- ifelse(dat$habitat=="Grassland",
runif(nrow(dat),0.5,1),   # higher confidence
runif(nrow(dat),0.1,0.6)) # lower confidence
# -----------------------------
# 2. Apply Two Thresholds
# -----------------------------
thresholds <- c(0.5, 0.9)
plot_list <- list()
for (th in thresholds) {
dat$det_obs <- ifelse(dat$prob > th, dat$det_ecol, 0)
obs_summary <- dat %>%
group_by(site, habitat) %>%
summarise(ever_detected = max(det_obs), .groups="drop") %>%
group_by(habitat) %>%
summarise(naive_occ = mean(ever_detected)) %>%
mutate(threshold = th)
plot_list[[as.character(th)]] <- obs_summary
}
plot_df <- bind_rows(plot_list)
plot_df$threshold <- factor(plot_df$threshold, labels=c("Threshold 0.5","Threshold 0.9"))
# Add true occupancy for reference
true_occ <- data.frame(habitat=c("Grassland","Woodland"),
true_occ=c(0.3,0.6))
plot_df <- merge(plot_df, true_occ, by="habitat")
# -----------------------------
# 3. Bar Chart: Threshold Effect Only
# -----------------------------
p <- ggplot(plot_df, aes(x=habitat, y=naive_occ, fill=threshold)) +
geom_bar(stat="identity", position="dodge") +
geom_point(aes(y=true_occ), color="forestgreen", size=4, shape=18) +
ylim(0,1) +
labs(title="Pine Marten Observed Detection: Threshold Choice Impact",
y="Observed Occupancy (bars) / True Occupancy (green diamond)",
x="Habitat") +
scale_fill_manual(values=c("Threshold 0.5"="goldenrod","Threshold 0.9"="orange")) +
theme_minimal(base_size=14) +
theme(legend.position="top")
# Display
print(p)
