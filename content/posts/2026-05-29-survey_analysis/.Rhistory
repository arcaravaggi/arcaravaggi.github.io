round(2) |>
print()
# в”Ђв”Ђ 4. Class Г— government cull support в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cat("\n=== Class Г— government cull support (row %) ===\n")
table(hare_lca$pred_class, hare_lca$support_gov_t_cull_decision) |>
prop.table(margin = 1) |>
round(2) |>
print()
# в”Ђв”Ђ 5. Class Г— conservation concern в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cat("\n=== Class Г— conservation concern (row %) ===\n")
table(hare_lca$pred_class, hare_lca$conservation_concern) |>
prop.table(margin = 1) |>
round(2) |>
print()
# в”Ђв”Ђ 6. Class Г— typology (validates against hand-coded types) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cat("\n=== Class Г— hand-coded typology (row %) ===\n")
table(hare_lca$pred_class, hare_lca$typology) |>
prop.table(margin = 1) |>
round(2) |>
print()
# в”Ђв”Ђ 7. Are class differences statistically significant? в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cat("\n=== Chi-square tests: class Г— external variables ===\n")
ext_vars <- c("group", "zone", "conservation_concern",
"support_gov_t_cull_decision")
map_dfr(ext_vars, function(v) {
tbl  <- table(hare_lca$pred_class, hare_lca[[v]])
test <- chisq.test(tbl)
tibble(
variable  = v,
chi_sq    = round(test$statistic, 2),
df        = test$parameter,
p_value   = round(test$p.value, 4),
sig       = case_when(test$p.value < 0.001 ~ "***",
test$p.value < 0.01  ~ "**",
test$p.value < 0.05  ~ "*",
TRUE                  ~ "ns")
)
}) |> print()
# в”Ђв”Ђ 8. Visualise all cross-tabulations in one panel plot в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
plot_cross <- function(var, label, data = hare_lca) {
data |>
filter(!is.na(.data[[var]])) |>
mutate(category = as.character(.data[[var]])) |>
count(pred_class, category) |>
group_by(pred_class) |>
mutate(pct = n / sum(n) * 100) |>
ggplot(aes(x = pct, y = pred_class, fill = category)) +
geom_col(width = 0.6) +
scale_x_continuous(labels = percent_format(scale = 1)) +
scale_fill_brewer(palette = "Set2") +
labs(title = label, x = NULL, y = NULL, fill = NULL) +
theme_minimal(base_size = 11) +
theme(legend.position = "bottom",
legend.text      = element_text(size = 8),
plot.title       = element_text(size = 11, face = "bold"))
}
p1 <- plot_cross("group",                        "Respondent group")
p2 <- plot_cross("zone",                         "Geographic zone")
p3 <- plot_cross("conservation_concern",         "Conservation concern")
(p1 + p2) / (p3 + p4) +
plot_annotation(
title    = "Latent class composition: external variable cross-tabulations",
subtitle = "Variables not used in the LCA вЂ” patterns here are data-driven, not assumed",
theme    = theme(plot.title    = element_text(size = 13, face = "bold"),
plot.subtitle = element_text(size = 10, colour = "grey40"))
)
p4 <- plot_cross("support_gov_t_cull_decision",  "Supports government cull")
(p1 + p2) / (p3 + p4) +
plot_annotation(
title    = "Latent class composition: external variable cross-tabulations",
subtitle = "Variables not used in the LCA вЂ” patterns here are data-driven, not assumed",
theme    = theme(plot.title    = element_text(size = 13, face = "bold"),
plot.subtitle = element_text(size = 10, colour = "grey40"))
)
hare_lca |>
filter(!is.na(group)) |>
count(pred_class, group) |>
group_by(pred_class) |>
mutate(pct = n / sum(n) * 100) |>
ggplot(aes(x = pct, y = pred_class, fill = group)) +
geom_col(width = 0.6) +
scale_fill_manual(values = c("CAI" = "#2166ac", "Public" = "#d73027")) +
scale_x_continuous(labels = percent_format(scale = 1)) +
labs(title    = "Latent class composition by respondent group",
subtitle = "Variables not used in LCA вЂ” this pattern was not assumed",
x = "% of class", y = NULL, fill = NULL) +
theme_minimal(base_size = 12) +
theme(legend.position = "top")
# Class sizes and assignment certainty
tibble(
class        = paste0("Class ", 1:K),
n            = tabulate(best_model$predclass),
pct          = round(tabulate(best_model$predclass) /
nrow(hare_lca) * 100, 1),
mean_post    = round(map_dbl(1:K, ~
mean(best_model$posterior[best_model$predclass == .x, .x])),
3),
mean_entropy = round(map_dbl(1:K, ~
mean(hare_lca$entropy[best_model$predclass == .x])),
3)
)|> print()
# Select and label the best model
best_model <- models[[which.min(map_dbl(models, ~ .x$bic))+1 ]]
cat("Best K by BIC:", which.min(map_dbl(models, ~ .x$bic)) + 1, "\n")
# Select and label the best model
best_model <- models[[which.min(map_dbl(models, ~ .x$bic)) ]+1]
# Select and label the best model
best_model <- models[[2]]   # models[[1]] = K=2, models[[2]] = K=3, etc.
K <- length(unique(best_model$predclass))
cat("Using K =", K, "classes\n")
# Extract item response probabilities
# probs[[item]][class, response] вЂ” we want response = 2 (TRUE)
probs_df <- imap_dfr(best_model$probs, function(mat, item) {
tibble(
item  = item,
class = paste0("Class ", seq_len(nrow(mat))),
prob  = mat[, 2]          # probability of YES (response = 2)
)
})
# Readable item labels
item_labels <- c(
seen_l_europaeus                      = "Seen European hare",
aware_of_2_sp_in_ni                   = "Aware of 2 species",
is_threat_of_l_europaeus_important    = "Threat important",
consider_hares_pests                  = "Hares are pests",
support_management_of_l_europaeus     = "Support management",
habitat_management_for_l_t_hibernicus = "Habitat management",
lethal_culling                        = "Lethal culling",
support_management_via_petition       = "Sign petition",
support_cull_with_direct_involvement  = "Direct involvement",
allow_cull_on_land                    = "Allow cull on land",
support_gov_t_cull_decision           = "Support govt cull"
)
probs_df <- probs_df |>
mutate(item = factor(item_labels[item], levels = rev(item_labels)))
# в”Ђв”Ђ Step 4: item probability plot в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ggplot(probs_df, aes(x = prob, y = item, colour = class)) +
geom_point(size = 3.5, alpha = 0.9) +
geom_line(aes(group = class), linewidth = 0.8, alpha = 0.6,
orientation = "y") +
geom_vline(xintercept = 0.5, linetype = "dashed", colour = "grey50") +
scale_x_continuous(labels = percent_format(), limits = c(0, 1)) +
scale_colour_brewer(palette = "Set1") +
labs(title    = "LCA item response probabilities by class",
subtitle = "Each point = P(Yes) for that item in that class В· dashed = 50%",
x = "Probability of Yes response", y = NULL, colour = NULL) +
facet_wrap(~ class, nrow = 1) +
theme_minimal(base_size = 12) +
theme(legend.position = "none",
panel.spacing    = unit(1.2, "lines"))
# Aassign class membership and cross-tabulate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# posterior gives P(class | response pattern); modal assignment = most likely class
lca_df$pred_class <- factor(best_model$predclass)
# Re-attach to main data (rows with NAs were dropped, so re-join by position)
